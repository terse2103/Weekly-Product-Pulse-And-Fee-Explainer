{
  "version": 2,
  "name": "weekly-product-pulse-frontend",
  "builds": [
    {
      "src": "phase6_web_ui/static/**",
      "use": "@vercel/static"
    },
    {
      "src": "api_server.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api_server.py"
    },
    {
      "src": "/(.*)",
      "dest": "phase6_web_ui/static/$1"
    }
  ]
}
