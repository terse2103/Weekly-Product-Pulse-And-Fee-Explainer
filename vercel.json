{
  "version": 2,
  "outputDirectory": "phase6_web_ui/static",
  "builds": [
    {
      "src": "phase6_web_ui/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://your-backend-url.com/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
