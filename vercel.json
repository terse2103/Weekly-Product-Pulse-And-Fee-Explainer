{
  "version": 2,
  "name": "weekly-product-pulse-frontend",
  "outputDirectory": "phase6_web_ui/static",
  "builds": [
    {
      "src": "phase6_web_ui/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
