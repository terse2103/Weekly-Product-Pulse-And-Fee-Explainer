# .streamlit/secrets.toml — Template for Streamlit Cloud Secrets
# ─────────────────────────────────────────────────────────────────
# Copy these values into the Streamlit Cloud dashboard:
#   App → Settings → Secrets
#
# DO NOT commit this file with real secrets — it is gitignored.
# A template version (secrets.toml.example) is committed instead.

# ── AI ────────────────────────────────────────────────────────────
GROQ_API_KEY = "gsk_..."

# ── SMTP / Email ──────────────────────────────────────────────────
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "465"
SMTP_USER = "you@gmail.com"
SMTP_PASS = "your-app-password"

# ── Google Docs (OAuth) ───────────────────────────────────────────
GDOC_ID              = "your-google-doc-id"
GOOGLE_CLIENT_ID     = "your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET = "GOCSPX-..."
GOOGLE_REFRESH_TOKEN = "1//..."

# ── Vercel Frontend URL (for CORS) ────────────────────────────────
# Set this to your deployed Vercel URL (e.g. https://weekly-pulse.vercel.app)
VERCEL_FRONTEND_URL  = "https://your-app.vercel.app"
